#!/bin/bash
##
## Post-publish hook: build musl binary and create GitHub release
##

set -e

VERSION=$(git describe --tags --exact-match 2>/dev/null) || {
    echo "Warning: not on a tag, skipping GitHub release" >&2
    exit 0
}

echo "=== Building static musl binary ===" >&2

./musl-static-build -f

BINARY="target/x86_64-unknown-linux-musl/release/shyaml"
if [ ! -f "$BINARY" ]; then
    echo "Error: musl binary not found at $BINARY" >&2
    exit 1
fi

ARTIFACT="shyaml-rs-${VERSION}-x86_64-linux-musl"
cp "$BINARY" "$ARTIFACT"

echo "Built: $ARTIFACT ($(du -h "$ARTIFACT" | cut -f1))" >&2

echo "=== Generating changelog ===" >&2

PREV_TAG=$(git tag --sort=-version:refname | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | grep -A1 "^${VERSION}$" | tail -1)

if [ "$PREV_TAG" = "$VERSION" ] || [ -z "$PREV_TAG" ]; then
    CHANGELOG=$(gitchangelog 2>/dev/null | tail -n +2 || echo "Initial release")
else
    CHANGELOG=$(gitchangelog "$PREV_TAG".."$VERSION" 2>/dev/null | tail -n +2 || echo "See commit history")
fi

echo "=== Creating GitHub release ===" >&2

## Resolve the GitHub "owner/repo" explicitly rather than relying on `gh`
## auto-detecting it from the current `origin`. `pkg` runs this hook inside a
## temporary clone created with `git clone . <tmp>`, so the clone's `origin`
## is a LOCAL filesystem path, not the github URL — `gh` then fails with
## "none of the git remotes point to a known GitHub host". Chase one hop from a
## local-path origin to reach the real github remote, then pass it via `--repo`.
origin=$(git remote get-url origin 2>/dev/null) || origin=
if [ -d "$origin" ]; then
    origin=$(git -C "$origin" remote get-url origin 2>/dev/null) || origin=
fi
repo=$(printf '%s\n' "$origin" |
    sed -nE 's#^(git@github\.com:|(ssh://)?git@github\.com/|https://github\.com/)([^/]+/[^/.]+)(\.git)?/?$#\3#p')
if [ -z "$repo" ]; then
    echo "Error: could not resolve a github.com owner/repo from origin '$origin'" >&2
    exit 1
fi

gh release create "$VERSION" \
    --repo "$repo" \
    --title "$VERSION" \
    --notes "$CHANGELOG" \
    "$ARTIFACT"

rm -f "$ARTIFACT"

echo "GitHub release created: $(gh release view "$VERSION" --repo "$repo" --json url -q .url)" >&2
